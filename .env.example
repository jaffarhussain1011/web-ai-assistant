# Copy to .env and fill in your values
# python-dotenv will load this automatically

# ── Ollama ─────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2          # or: mistral, phi3, llama3.1, etc.
OLLAMA_TIMEOUT=300             # seconds to wait for a response (increase for slow/large models)
OLLAMA_KEEP_ALIVE=10m          # how long to keep model in RAM after last request

# ── Server ─────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
